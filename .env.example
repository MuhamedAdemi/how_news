# Kopjo si .env dhe plotëso vlerat
# cp .env.example .env  (Linux/Mac)
# copy .env.example .env  (Windows)

# ------------------------------------------------------------------
# I detyrueshëm
# ------------------------------------------------------------------

# Gjenero me:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=ndrysho-kete-me-nje-celes-te-ri-secret

# Hostet e lejuar (pa http://, pa /)
ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------------
# Databaza
# ------------------------------------------------------------------

# SQLite (dev — lëre bosh ose hiqe)
DATABASE_URL=

# PostgreSQL me Docker Compose:
# DATABASE_URL=postgres://how_news:how_news_pass@db:5432/how_news

# PostgreSQL server i jashtëm:
# DATABASE_URL=postgres://user:password@host:5432/how_news

# ------------------------------------------------------------------
# Produksion (Docker)
# ------------------------------------------------------------------

# Origjinat për CSRF (me protokoll dhe port nëse jo standard)
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# URL bazë e admin Wagtail — përdoret në email-et e njoftimit
WAGTAILADMIN_BASE_URL=http://localhost:8000
