# Kopjo këtë skedar si .env dhe plotëso vlerat
# cp .env.example .env

# Django secret key - gjenero një të re me:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=ndrysho-kete-me-nje-celes-te-ri-secret

# Hostet e lejuar (p.sh. për produksion: mysite.com,www.mysite.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# URL e bazës së të dhënave (lëre bosh për SQLite)
# Shembull PostgreSQL: postgres://user:password@localhost:5432/how_news
DATABASE_URL=
